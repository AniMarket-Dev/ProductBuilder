APP_URL=http://localhost:3000
INSALES_SHOP_URL=https://example.myinsales.ru
INSALES_API_KEY=
INSALES_API_PASSWORD=
# Supabase Postgres URI
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase Storage S3 Access Key ID
STORAGE_ACCESS_KEY=

# Supabase Storage S3 Secret Access Key
STORAGE_SECRET_KEY=

# Public bucket name in Supabase Storage
STORAGE_BUCKET=constructor-assets

# Public base URL of the bucket, without file name
STORAGE_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public/constructor-assets

# S3-compatible endpoint from Supabase Storage
STORAGE_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3

# Region from Supabase project settings / S3 configuration
STORAGE_REGION=<project-region>

ALLOWED_ORIGINS=https://example.myinsales.ru,http://localhost:3000
MAX_UPLOAD_SIZE_MB=15
